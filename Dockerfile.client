# Dockerfile for the React client
FROM node:18-alpine AS build

WORKDIR /app

# Install dependencies
COPY client/package.json client/package-lock.json ./
RUN npm install

# Build the client
COPY client/ ./
RUN npm run build

# Serve the built app
FROM nginx:alpine
COPY --from=build /app/dist /usr/share/nginx/html
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]